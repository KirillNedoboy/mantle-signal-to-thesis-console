{
  "name": "mantle-signal-to-thesis-console",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "type": "module",
  "description": "Self-hosted AI research console that turns Web3 scanner outputs into structured Mantle ecosystem research objects.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
